# Label Studio local file serving (required for /data/local-files/ image URLs)
# Use: source label_studio.env   OR   ./start_label_studio.sh

LOCAL_FILES_SERVING_ENABLED=true
LOCAL_FILES_DOCUMENT_ROOT=/home/kaushik/Nepali_Num_plate

# Aliases (same values; supported by Label Studio)
LABEL_STUDIO_LOCAL_FILES_SERVING_ENABLED=true
LABEL_STUDIO_LOCAL_FILES_DOCUMENT_ROOT=/home/kaushik/Nepali_Num_plate
